# Shopify CLI Theme Access token — create one in the Theme Access app
# (https://shopify.dev/docs/storefronts/themes/tools/theme-access).
# Format: shptka_...  Equivalent to `shopify theme <cmd> --password <token>`.
#
# Shopify CLI reads SHOPIFY_CLI_THEME_TOKEN from the real environment; it does
# NOT auto-load this file for theme commands. Load it locally with direnv
# (.envrc containing `dotenv`) or `set -a; source .env; set +a` before running
# shopify commands. In CI, set it as a masked secret rather than committing a file.
SHOPIFY_CLI_THEME_TOKEN=

# Multiple environments on different stores? Don't reuse one token for all of
# them — give each its own key and pass it per command, e.g.
#   shopify theme push -e staging --password "$SHOPIFY_CLI_THEME_TOKEN_STAGING"
# SHOPIFY_CLI_THEME_TOKEN_STAGING=
# SHOPIFY_CLI_THEME_TOKEN_PRODUCTION=
